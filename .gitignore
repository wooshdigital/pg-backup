# =============================================================================
# pg-s3-backup — .gitignore
# =============================================================================

# Compiled binaries
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Dependency vendor directory (if used)
vendor/

# Environment / secrets — never commit real values
.env
*.env
!.env.example

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# Linux
*~

# Config files with real secrets
config.yaml
!config.yaml.example

# Temporary files
tmp/