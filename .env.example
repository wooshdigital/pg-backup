# =============================================================================
# pg-s3-backup — Example Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values, or export these variables
# in your shell / container environment.
#
# All variables are prefixed with BACKUP_.
# Values in environment variables always override config.yaml entries.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Full DSN for the PostgreSQL database to back up.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
BACKUP_DB_DSN=postgres://user:secret@localhost:5432/mydb?sslmode=disable

# -----------------------------------------------------------------------------
# AWS S3
# -----------------------------------------------------------------------------
# Name of the S3 bucket where backup files are uploaded.
BACKUP_S3_BUCKET=my-backup-bucket

# AWS region where the bucket lives.
BACKUP_S3_REGION=us-east-1

# Optional key prefix (folder) within the bucket. Trailing slash is conventional.
# Default: backups/
BACKUP_S3_PREFIX=backups/

# -----------------------------------------------------------------------------
# Backup schedule
# -----------------------------------------------------------------------------
# Standard cron expression controlling when backups run (UTC).
# Default: "0 2 * * *" — every day at 02:00 UTC
BACKUP_SCHEDULE=0 2 * * *

# -----------------------------------------------------------------------------
# Retention
# -----------------------------------------------------------------------------
# Number of days to keep old backup files before they are deleted from S3.
# Must be a positive integer. Default: 30
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Verbosity level for structured JSON logs.
# One of: trace, debug, info, warn, error, fatal, panic
# Default: info
BACKUP_LOG_LEVEL=info