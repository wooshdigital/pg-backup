# pg-s3-backup — example environment variables
# Copy this file to .env and fill in real values.
# Lines starting with # are comments and are ignored.
#
# Environment variables take the highest precedence and override anything
# set in config.yaml.  All variables must be prefixed with BACKUP_.

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string passed to pg_dump.
BACKUP_DATABASE_DSN=postgres://user:password@localhost:5432/mydb?sslmode=disable

# ── S3 Storage ────────────────────────────────────────────────────────────────
BACKUP_S3_BUCKET=my-backup-bucket
BACKUP_S3_REGION=us-east-1

# Optional key prefix inside the bucket (defaults to "backups/")
BACKUP_S3_PREFIX=backups/

# ── AWS credentials ───────────────────────────────────────────────────────────
# The worker respects the standard AWS credential chain:
#   1. Environment variables below
#   2. ~/.aws/credentials
#   3. IAM instance role / ECS task role
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=   # only needed for temporary credentials

# ── Schedule ──────────────────────────────────────────────────────────────────
# Cron expression (UTC). Defaults to "0 2 * * *" (daily at 02:00 UTC).
BACKUP_SCHEDULE=0 2 * * *

# ── Retention ─────────────────────────────────────────────────────────────────
# Days to keep backups. 0 = keep forever. Defaults to 30.
BACKUP_RETENTION_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal | panic — defaults to info
BACKUP_LOG_LEVEL=info