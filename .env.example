# pg-s3-backup — example environment variables
#
# Copy this file to .env, fill in your values, and source it before running:
#
#   cp .env.example .env
#   $EDITOR .env
#   source .env          # for a local shell session
#
# Or pass the file directly to Docker:
#
#   docker run --env-file .env pg-s3-backup
#
# All variables must be prefixed with BACKUP_.
# Environment variables always override values in config.yaml.

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# libpq-compatible connection string.
# Required.
BACKUP_DATABASE_DSN=postgres://backup_user:changeme@localhost:5432/mydb?sslmode=require

# ── Amazon S3 ─────────────────────────────────────────────────────────────────

# S3 bucket name.
# Required.
BACKUP_S3_BUCKET=my-backup-bucket

# AWS region.
# Required.
BACKUP_S3_REGION=us-east-1

# Optional key prefix inside the bucket.
# Default: backups/
BACKUP_S3_PREFIX=backups/

# ── Schedule ──────────────────────────────────────────────────────────────────

# 5-field cron expression (UTC).
# Default: 0 2 * * *  (daily at 02:00 UTC)
BACKUP_SCHEDULE=0 2 * * *

# ── Retention ─────────────────────────────────────────────────────────────────

# Days of backups to keep. Must be >= 1.
# Default: 30
BACKUP_RETENTION_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level: trace | debug | info | warn | error | fatal | panic
# Default: info
BACKUP_LOG_LEVEL=info

# ── AWS credentials ───────────────────────────────────────────────────────────
# These are standard AWS SDK environment variables, not prefixed with BACKUP_.
# Alternatively, use an IAM role or ~/.aws/credentials.

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=   # only needed for temporary credentials