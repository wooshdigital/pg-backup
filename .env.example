# pg-s3-backup environment variable configuration
# Copy this file to .env and fill in your values.
# Environment variables take precedence over config.yaml.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgres://[user[:password]@][host][:port]/[dbname][?param1=value1&...]
PG_S3_BACKUP_DATABASE_DSN=postgres://user:password@localhost:5432/mydb?sslmode=disable

# S3 bucket name where backups will be stored
PG_S3_BACKUP_S3_BUCKET=my-backup-bucket

# AWS region of the S3 bucket
PG_S3_BACKUP_S3_REGION=us-east-1

# ── Optional (shown with defaults) ────────────────────────────────────────────

# Key prefix (folder) inside the S3 bucket
# PG_S3_BACKUP_S3_PREFIX=backups/

# Cron expression for backup schedule (default: daily at 2 AM UTC)
# PG_S3_BACKUP_SCHEDULE=0 2 * * *

# Number of days to retain backups before automatic deletion (min: 1)
# PG_S3_BACKUP_RETENTION_DAYS=30

# Log verbosity: debug | info | warn | error
# PG_S3_BACKUP_LOG_LEVEL=info

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Use any standard AWS credential method:
#   - Environment variables below
#   - ~/.aws/credentials file
#   - IAM instance role (recommended for EC2/ECS)

# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=               # Only needed for temporary credentials