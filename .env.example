# pg-s3-backup — example environment variables
# Copy this file to .env and fill in real values.
# All variables must be prefixed with BACKUP_.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
BACKUP_DATABASE_DSN=postgres://user:password@localhost:5432/mydb?sslmode=disable

# ---------------------------------------------------------------------------
# S3 / Object Storage (required)
# ---------------------------------------------------------------------------
BACKUP_S3_BUCKET=my-pg-backups
BACKUP_S3_REGION=us-east-1

# Optional path prefix inside the bucket (default: backups/)
BACKUP_S3_PREFIX=backups/

# ---------------------------------------------------------------------------
# AWS credentials — use IAM roles in production instead of static keys
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ---------------------------------------------------------------------------
# Scheduling & Retention
# ---------------------------------------------------------------------------

# 5-field cron expression (default: "0 2 * * *" — daily at 02:00 UTC)
BACKUP_SCHEDULE=0 2 * * *

# Days to keep old backups (default: 30)
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# trace | debug | info | warn | error | fatal  (default: info)
BACKUP_LOG_LEVEL=info