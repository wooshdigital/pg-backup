# pg-s3-backup — Environment Variable Reference
# Copy to .env and fill in your values (never commit .env to version control).
# All variables are prefixed with PG_S3_BACKUP_.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
PG_S3_BACKUP_DATABASE_DSN=postgres://myuser:mypassword@localhost:5432/mydb?sslmode=disable

# S3 bucket name.
PG_S3_BACKUP_S3_BUCKET=my-postgres-backups

# AWS region.
PG_S3_BACKUP_S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Optional (defaults shown)
# ---------------------------------------------------------------------------

# Key prefix inside the S3 bucket.
PG_S3_BACKUP_S3_PREFIX=backups/

# Cron schedule (daily at 02:00 UTC).
PG_S3_BACKUP_SCHEDULE=0 2 * * *

# Number of days to keep backups.
PG_S3_BACKUP_RETENTION_DAYS=30

# Log verbosity: debug | info | warn | error | fatal | panic
PG_S3_BACKUP_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# AWS credentials (if not using an IAM role / instance profile)
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=      # only needed for temporary credentials