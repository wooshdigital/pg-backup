# pg-s3-backup environment variable reference
# Copy to .env and populate with real values. Never commit the filled-in file.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
# PostgreSQL connection string.
BACKUP_DATABASE_DSN=postgres://user:password@localhost:5432/mydb?sslmode=disable

# ---------------------------------------------------------------------------
# S3 / Object Storage (required)
# ---------------------------------------------------------------------------
# Target S3 bucket name.
BACKUP_S3_BUCKET=my-pg-backups

# AWS region of the bucket.
BACKUP_S3_REGION=us-east-1

# Optional prefix / folder inside the bucket. Default: backups/
BACKUP_S3_PREFIX=backups/

# ---------------------------------------------------------------------------
# Scheduling (optional — default: "0 2 * * *")
# ---------------------------------------------------------------------------
# Standard 5-field cron expression.
BACKUP_SCHEDULE=0 2 * * *

# ---------------------------------------------------------------------------
# Retention (optional — default: 30)
# ---------------------------------------------------------------------------
# Number of days to keep old backups before deleting them from S3.
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Logging (optional — default: info)
# ---------------------------------------------------------------------------
# One of: trace, debug, info, warn, error, fatal, panic
BACKUP_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Config file (optional)
# ---------------------------------------------------------------------------
# Absolute or relative path to a YAML config file.
# When set, this file is loaded in addition to (and overridden by) env vars.
# BACKUP_CONFIG_FILE=/etc/pg-s3-backup/config.yaml