# pg-s3-backup — environment variable configuration
# Copy this file to .env, fill in your values, then: source .env
#
# All variables must be prefixed with BACKUP_.
# Environment variables override values in config.yaml.

# ---------------------------------------------------------------------------
# PostgreSQL connection (required)
# ---------------------------------------------------------------------------
# Full PostgreSQL DSN.
# Example: postgres://user:password@localhost:5432/mydb?sslmode=disable
BACKUP_DATABASE_DSN=postgres://user:password@localhost:5432/mydb?sslmode=disable

# ---------------------------------------------------------------------------
# S3 / object storage (required)
# ---------------------------------------------------------------------------
# Name of the destination S3 bucket.
BACKUP_S3_BUCKET=my-database-backups

# AWS region hosting the bucket.
BACKUP_S3_REGION=us-east-1

# Optional key prefix inside the bucket (acts like a folder).
BACKUP_S3_PREFIX=backups/

# ---------------------------------------------------------------------------
# Backup schedule & retention (optional — defaults shown)
# ---------------------------------------------------------------------------
# Cron expression (UTC).  Default: daily at 02:00.
BACKUP_SCHEDULE="0 2 * * *"

# Days to keep backups before pruning.  Default: 30.
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Logging (optional — default: info)
# ---------------------------------------------------------------------------
# One of: trace | debug | info | warn | error | fatal | panic
BACKUP_LOG_LEVEL=info