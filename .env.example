# pg-s3-backup — example environment variables
# Copy to .env and source it, or export the variables directly in your shell /
# container environment. All variables must be prefixed with BACKUP_.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full connection DSN for the source PostgreSQL database.
BACKUP_DATABASE_DSN=postgres://user:password@localhost:5432/mydb?sslmode=disable

# ── S3 / Object Storage ───────────────────────────────────────────────────────
BACKUP_S3_BUCKET=my-backup-bucket
BACKUP_S3_REGION=us-east-1

# Optional key prefix inside the bucket (defaults to "backups/")
BACKUP_S3_PREFIX=backups/

# ── Backup Schedule ───────────────────────────────────────────────────────────
# 5-field cron expression (UTC). Defaults to "0 2 * * *" (daily at 02:00 UTC).
BACKUP_SCHEDULE=0 2 * * *

# ── Retention ─────────────────────────────────────────────────────────────────
# Days to retain old backups (default: 30).
BACKUP_RETENTION_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
# Zerolog log level: trace | debug | info | warn | error | fatal | panic
# Defaults to "info".
BACKUP_LOG_LEVEL=info