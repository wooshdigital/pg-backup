database:
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

storage:
  bucket: "my-backups"
  region: "us-east-1"
  # endpoint is optional; set for LocalStack or other S3-compatible services
  endpoint: ""
  access_key_id: ""
  secret_access_key: ""
  force_path_style: false

compress:
  # Supported algorithms: gzip, zstd, none
  algorithm: "gzip"

backup:
  # stream_direct: if true, skip the temp file and pipe dump→compress→upload directly
  stream_direct: false