database:
  # Provide a full DSN or individual fields
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"
  # Alternatively, use individual fields:
  # host: localhost
  # port: 5432
  # user: postgres
  # password: secret
  # name: mydb
  # ssl_mode: disable

output_dir: "/var/backups/postgres"

# compression_format controls how the pg_dump output is compressed.
# Supported values: gzip (default), zstd, none
compression_format: "gzip"

# compression_level controls the compression level.
# For gzip: -2 (HuffmanOnly) to 9 (BestCompression), or 0 for default (-1 internally).
# For zstd: ignored (use zstd encoder level constants).
# Leave as 0 to use the format's default level.
compression_level: 0

# dump_timeout is the maximum time allowed for a single dump operation.
# Uses Go duration syntax: 30m, 1h, etc.
dump_timeout: "30m"