# Example configuration for the pg_dump worker.

database:
  host: localhost
  port: 5432
  name: mydb
  user: postgres
  password: ""
  ssl_mode: disable

storage:
  output_dir: /var/dumps

compression:
  # format: gzip | zstd | none
  format: gzip
  # level: compression level
  #   gzip: -1 (default), 1 (fastest) – 9 (best compression)
  #   zstd:  0 (default),  1 (fastest) – 4 (best compression)
  level: -1