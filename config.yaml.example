database:
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

storage:
  path: "/var/backups/pgdumps"

worker:
  schedule: "0 2 * * *"   # daily at 02:00 UTC

compress:
  # Compression format: gzip, zstd, or none
  format: gzip
  # Compression level:
  #   gzip: 1 (fastest) to 9 (best), 0 = default
  #   zstd: 1 (fastest) to 4 (best), 0 = default
  level: 0