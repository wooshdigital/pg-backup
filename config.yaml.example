# Example configuration for the DB backup worker.
# Copy this file to config.yaml and adjust for your environment.

worker:
  # Cron schedule for backup runs (default: daily at 02:00 UTC).
  schedule: "0 2 * * *"
  # Maximum duration for a single backup run.
  timeout: 2h

database:
  # Full DSN for the source database.
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"
  # Logical name used in key templates. Inferred from DSN if omitted.
  name: mydb

storage:
  # Backend to use: "s3" (default) or "local" (for dev/testing).
  backend: s3

  s3:
    # Target S3 bucket. Required.
    bucket: my-db-backups

    # AWS region. Required.
    region: us-east-1

    # Custom endpoint URL (for LocalStack / MinIO). Omit for real AWS.
    # endpoint: http://localhost:4566

    # Use path-style addressing. Required for LocalStack / MinIO.
    # use_path_style: true

    # Key template for uploaded objects.
    # Placeholders: {db}, {date}, {timestamp}, {hostname}
    prefix_template: "backups/{db}/{date}/{timestamp}/dump.sql.gz"

    # Multipart upload part size in bytes (default: 5 MB).
    part_size_bytes: 5242880

    # Number of parallel upload goroutines (default: 5).
    concurrency: 5

    # Maximum retry attempts on transient errors (default: 3).
    max_retries: 3

    # Optional static credentials.
    # When omitted, the default credential chain is used (env vars, IAM role, etc.).
    # credentials:
    #   access_key_id: AKIAIOSFODNN7EXAMPLE
    #   secret_access_key: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
    #   session_token: ""   # Optional STS session token.

  # Local filesystem backend settings (used when backend: local).
  local:
    base_dir: /var/backups/db

compress:
  # Compression algorithm: "gzip" (default) or "zstd".
  algorithm: gzip
  # Compression level (algorithm-specific; 0 = default).
  level: 6