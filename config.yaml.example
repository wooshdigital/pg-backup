# pg-s3-backup configuration file
# Copy this file to config.yaml and fill in the values.
# Environment variables (prefixed BACKUP_) take precedence over values here.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=SSLMODE
# Env var: BACKUP_DATABASE_DSN
database_dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

# ---------------------------------------------------------------------------
# S3 / Object Storage
# ---------------------------------------------------------------------------

# Name of the S3 bucket where backups will be stored.
# Env var: BACKUP_S3_BUCKET
s3_bucket: "my-pg-backups"

# AWS region containing the bucket.
# Env var: BACKUP_S3_REGION
s3_region: "us-east-1"

# Optional key prefix (acts like a folder) within the bucket.
# Default: "backups/"
# Env var: BACKUP_S3_PREFIX
s3_prefix: "backups/"

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------

# Cron expression controlling backup frequency.
# Default: "0 2 * * *"  (every day at 02:00 UTC)
# Env var: BACKUP_SCHEDULE
schedule: "0 2 * * *"

# ---------------------------------------------------------------------------
# Retention
# ---------------------------------------------------------------------------

# Number of days to keep old backups in S3.
# Backups older than this value will be deleted.
# Default: 30
# Env var: BACKUP_RETENTION_DAYS
retention_days: 30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity level.
# Valid values: trace, debug, info, warn, error, fatal, panic
# Default: info
# Env var: BACKUP_LOG_LEVEL
log_level: "info"