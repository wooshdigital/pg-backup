# Database connection
database:
  host: "localhost"
  port: 5432
  name: "mydb"
  user: "postgres"
  password: "secret"

# Backup schedule (cron expression, standard 5-field format)
schedule:
  # Default: every day at 02:00 AM
  cron_expression: "0 2 * * *"

# Compression settings
compress:
  algorithm: "gzip"   # supported: gzip, zstd

# Storage backend
storage:
  backend: "s3"       # supported: s3, local
  bucket: "my-backups"
  prefix: "postgres"
  region: "us-east-1"
  endpoint: ""        # leave empty for AWS S3; set for MinIO, etc.

# Local storage (used when storage.backend = "local")
local:
  path: "/var/backups/postgres"

# Temporary directory for dump and archive files
temp_dir: "/tmp"