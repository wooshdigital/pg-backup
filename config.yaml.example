# Example configuration for the dump worker.
# Copy to config.yaml and fill in the values.

database:
  # PostgreSQL connection string (DSN).
  # Supports all libpq connection string formats.
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=require"

storage:
  # Directory where dump files are written.
  # The directory will be created if it does not exist.
  directory: "/var/dumps"

compression:
  # Compression format: gzip, zstd, or none.
  # Default: gzip
  format: "gzip"

  # Compression level (format-specific):
  #   gzip:  1 (fastest) to 9 (best), -1 for default (≈6)
  #   zstd:  1 (fastest) to 4 (best),  0 for default
  #   none:  ignored
  level: -1

schedule:
  # Standard cron expression for when dumps run.
  cron: "0 2 * * *"   # daily at 02:00 UTC

  # Maximum time allowed for a single dump run.
  timeout: "30m"