# Example configuration for the backup worker.
# Copy to config.yaml and fill in your values.

database:
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

storage:
  endpoint: ""            # Leave empty for real AWS S3; set for LocalStack, e.g. http://localhost:4566
  bucket: "my-backups"
  region: "us-east-1"
  access_key_id: ""       # Uses AWS_ACCESS_KEY_ID env var if empty
  secret_access_key: ""   # Uses AWS_SECRET_ACCESS_KEY env var if empty
  force_path_style: false # Set to true when using LocalStack or MinIO
  key_prefix: "backups"   # Object key prefix, e.g. "prod/postgres"

compress:
  level: 6  # gzip compression level 1-9 (default 6)

# stream_direct: true  # Stream directly from pg_dump → compressor → S3 without a temp file
stream_direct: false