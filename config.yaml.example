# =============================================================================
# pg-s3-backup — Example Configuration File
# =============================================================================
# Rename this file to config.yaml and place it in the working directory, or
# at /etc/pg-s3-backup/config.yaml.
#
# Environment variables (prefixed with BACKUP_) always take precedence over
# values set here.  See .env.example for the full list of env var names.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL connection
# -----------------------------------------------------------------------------
# Full DSN for the source database.
db_dsn: "postgres://user:secret@localhost:5432/mydb?sslmode=disable"

# -----------------------------------------------------------------------------
# AWS S3 destination
# -----------------------------------------------------------------------------
s3_bucket: "my-backup-bucket"
s3_region: "us-east-1"

# Optional prefix (folder path) within the bucket.
# Default: "backups/"
s3_prefix: "backups/"

# -----------------------------------------------------------------------------
# Schedule
# -----------------------------------------------------------------------------
# Standard five-field cron expression (UTC).
# Examples:
#   "0 2 * * *"   — daily at 02:00 UTC
#   "0 */6 * * *" — every 6 hours
#   "0 2 * * 0"   — weekly on Sunday at 02:00 UTC
# Default: "0 2 * * *"
schedule: "0 2 * * *"

# -----------------------------------------------------------------------------
# Retention
# -----------------------------------------------------------------------------
# How many days to keep old backup objects in S3 before deleting them.
# Default: 30
retention_days: 30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Structured log verbosity.
# One of: trace | debug | info | warn | error | fatal | panic
# Default: "info"
log_level: "info"