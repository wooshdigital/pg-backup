# Example configuration for dbworker.
# Copy to config.yaml and fill in your values.

database:
  # PostgreSQL connection string.
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

storage:
  # Directory where dump files will be written.
  output_dir: "/var/backups/dbdumps"

compression:
  # Algorithm: gzip | zstd | none
  format: gzip
  # Compression level (algorithm-dependent):
  #   gzip: -1 (default), 1 (fastest) … 9 (best compression)
  #   zstd:  1 (fastest) … 4 (best compression)
  #   none:  ignored
  level: -1