# pg-dump-worker example configuration

# PostgreSQL connection string.
database_url: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

# Directory where dump files will be written.
output_dir: "/var/backups/pg-dumps"

# Compression algorithm to use: none | gzip | zstd
# Defaults to "gzip" when omitted.
compression_format: "gzip"

# Algorithm-specific compression level.
#   gzip: 1 (BestSpeed) – 9 (BestCompression); 0 → default (-1, equivalent to 6)
#   zstd: 1 (Fastest)   – 4 (BestCompression);  0 → default (3)
#   none: ignored
compression_level: 6