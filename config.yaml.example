# pg-s3-backup configuration file
# Copy to config.yaml and fill in your values.
# Environment variables (BACKUP_*) override values set here.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN for the source database.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
database_dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

# ── S3 / Object Storage ───────────────────────────────────────────────────────
# Name of the S3 bucket where backups will be stored.
s3_bucket: "my-backup-bucket"

# AWS region that hosts the bucket.
s3_region: "us-east-1"

# Optional key prefix (acts as a folder path) inside the bucket.
# Trailing slash is recommended.
s3_prefix: "backups/"

# ── Backup Schedule ───────────────────────────────────────────────────────────
# Standard 5-field cron expression (UTC).
# Examples:
#   "0 2 * * *"    → daily at 02:00 UTC
#   "0 */6 * * *"  → every 6 hours
#   "0 2 * * 0"    → weekly on Sunday at 02:00 UTC
schedule: "0 2 * * *"

# ── Retention ─────────────────────────────────────────────────────────────────
# Number of days to keep backup files in S3.
# Backups older than this will be deleted automatically.
retention_days: 30

# ── Logging ───────────────────────────────────────────────────────────────────
# Zerolog log level.
# Valid values: trace, debug, info, warn, error, fatal, panic
log_level: "info"