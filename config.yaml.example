# pg-s3-backup configuration file
# Copy this file to config.yaml and fill in the values.
#
# Environment variables prefixed with BACKUP_ always override values set here.
# Example: BACKUP_DATABASE_DSN overrides database_dsn below.

# ---------------------------------------------------------------------------
# PostgreSQL connection
# ---------------------------------------------------------------------------

# Full DSN for the PostgreSQL database to back up.
# Format: postgres://[user[:password]@][host][:port]/[dbname][?param=value&...]
database_dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

# ---------------------------------------------------------------------------
# S3 / object storage
# ---------------------------------------------------------------------------

# Name of the S3 bucket where backup archives will be uploaded.
s3_bucket: "my-database-backups"

# AWS region that hosts the bucket.
s3_region: "us-east-1"

# Optional key prefix (acts as a folder) within the bucket.
# Trailing slash is recommended.
s3_prefix: "backups/"

# ---------------------------------------------------------------------------
# Backup schedule & retention
# ---------------------------------------------------------------------------

# Cron expression controlling how often backups run (evaluated in UTC).
# Default: daily at 02:00 UTC
# Examples:
#   "0 2 * * *"     — daily at 02:00
#   "0 */6 * * *"   — every 6 hours
#   "0 2 * * 0"     — weekly on Sunday at 02:00
schedule: "0 2 * * *"

# Number of days to retain backups.
# Backups older than this will be deleted during the pruning phase.
retention_days: 30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity level.
# Valid values: trace | debug | info | warn | error | fatal | panic
log_level: "info"