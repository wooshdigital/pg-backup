# pg-dump-worker configuration example

# PostgreSQL connection URL or DSN.
database_url: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

# Directory where dump artifacts will be written.
output_dir: "/var/backups/pg-dumps"

# Maximum time to allow pg_dump to run before cancellation.
dump_timeout: 30m

# Compression format: gzip | zstd | none
# Default: gzip
compression_format: gzip

# Compression level.
# gzip: 1 (BestSpeed) – 9 (BestCompression), -1 = default (6)
# zstd: 1 (Fastest) – 4 (BestCompression), 0 = default (2)
# Ignored when compression_format is "none".
compression_level: 6