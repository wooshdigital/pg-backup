# pgdumper configuration example
# Copy to config.yaml and adjust to your environment.

# PostgreSQL connection string (URL or key=value format).
# Examples:
#   postgres://user:password@host:5432/dbname?sslmode=require
#   host=localhost port=5432 user=postgres dbname=mydb sslmode=disable
dsn: "postgres://user:password@localhost:5432/mydb?sslmode=require"

# Directory where dump files are written.
output_dir: "/var/backups/pgdumper"

# Cron schedule for automatic dumps (optional; leave empty to run once and exit).
# Example: every day at 02:00 UTC
schedule: "0 2 * * *"

pg_dump:
  # Absolute path to pg_dump binary. Leave empty to use the one on PATH.
  binary_path: ""

  # Output format: plain | custom | directory | tar
  # "custom" is recommended: it supports parallel restore and compression.
  format: "custom"

  # Additional arguments passed verbatim to pg_dump.
  extra_args:
    - "--compress=9"
    - "--no-owner"
    - "--no-acl"

retention:
  # Delete dump files older than this duration (e.g. 168h = 7 days).
  max_age: 168h

  # Keep at most this many dump files (0 = no limit).
  max_count: 7