# Example configuration file for dbworker.
# Copy this file to config.yaml and adjust values for your environment.

database:
  host: localhost
  port: 5432
  name: mydb
  user: postgres
  password: ""
  ssl_mode: disable

storage:
  # backend selects the storage destination.
  # Supported values: "s3" (default), "local"
  backend: s3

  s3:
    # Target S3 bucket (required for backend=s3).
    bucket: my-backup-bucket

    # AWS region (required for backend=s3).
    region: us-east-1

    # Optional: override the S3 endpoint (useful for LocalStack / MinIO).
    # endpoint: http://localhost:4566

    # Optional: force path-style S3 addressing (required for LocalStack).
    # force_path_style: true

    # S3 object key template.
    # Supported placeholders: {db}, {date}, {timestamp}, {hostname}
    key_prefix: "backups/{db}/{date}/{timestamp}.sql.gz"

    # Multipart upload part size in bytes (default: 5242880 = 5 MiB).
    part_size: 5242880

    # Number of parallel goroutines for multipart upload (default: 5).
    concurrency: 5

    # Maximum retry attempts on transient errors (default: 3).
    max_retries: 3

    # Optional explicit AWS credentials.
    # When omitted, the SDK uses its default credential chain:
    #   1. IAM role (recommended for production)
    #   2. Environment variables (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
    #   3. ~/.aws/credentials
    credentials:
      access_key_id: ""
      secret_access_key: ""

  local:
    # Base directory for the local filesystem backend (required for backend=local).
    base_dir: /var/backups/dbworker

compress:
  # Compression algorithm: "gzip" (default), "zstd", or "none".
  algorithm: gzip
  # Compression level (algorithm-specific, 0 = default).
  level: 6

worker:
  # Cron expression for the backup schedule.
  schedule: "0 2 * * *"
  # Maximum duration for a single backup run (e.g. "2h", "30m").
  timeout: 2h
  # Directory for temporary files during backup.
  temp_dir: /tmp