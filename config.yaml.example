database:
  dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

storage:
  bucket: "my-backup-bucket"
  region: "us-east-1"
  # endpoint: "http://localhost:4566"  # Uncomment for LocalStack / MinIO

compress:
  algorithm: "gzip"  # Supported: gzip, none

backup:
  stream_direct: false  # Set to true to skip temp file and stream directly to S3