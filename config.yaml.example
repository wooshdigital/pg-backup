# pg-s3-backup — example configuration file
# Copy this file to config.yaml and fill in your values.
# Environment variables (BACKUP_*) take precedence over values here.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string (required).
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
database_dsn: "postgres://user:password@localhost:5432/mydb?sslmode=disable"

# ---------------------------------------------------------------------------
# S3 / Object Storage
# ---------------------------------------------------------------------------

# S3 bucket to upload backups into (required).
s3_bucket: "my-pg-backups"

# AWS region that hosts the bucket (required).
s3_region: "us-east-1"

# Optional key prefix (folder path) inside the bucket.
# Default: backups/
s3_prefix: "backups/"

# ---------------------------------------------------------------------------
# Scheduling & Retention
# ---------------------------------------------------------------------------

# Standard 5-field cron expression controlling when backups run.
# Default: "0 2 * * *"  (daily at 02:00 UTC)
# Examples:
#   "*/30 * * * *"   — every 30 minutes
#   "0 */6 * * *"    — every 6 hours
#   "0 3 * * 0"      — weekly on Sunday at 03:00
schedule: "0 2 * * *"

# Number of days to retain old backups before deletion.
# Default: 30
retention_days: 30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity level.
# One of: trace | debug | info | warn | error | fatal
# Default: info
log_level: "info"