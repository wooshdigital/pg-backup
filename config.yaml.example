database:
  dsn: "postgres://postgres:password@localhost:5432/mydb?sslmode=disable"

storage:
  bucket: "my-backups"
  region: "us-east-1"
  # Optional: set for LocalStack or other S3-compatible services.
  endpoint: ""
  force_path_style: false
  # Optional: leave empty to use IAM roles / environment credentials.
  access_key_id: ""
  secret_access_key: ""

compression:
  algorithm: "gzip"   # supported: "gzip"

backup:
  # When true, compressed data is piped directly to S3 without a temp file.
  stream_direct: false